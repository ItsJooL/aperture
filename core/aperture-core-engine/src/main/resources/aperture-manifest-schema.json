{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "apiVersion": { "type": "string" },
    "kind": { 
      "type": "string",
      "enum": ["Entity", "OneOf", "Migration", "ApertureConfig", "RoleDefinition", "AbacPolicy", "ApiVersionConfig", "PrincipalAttributeDefinition"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "spec": { "type": "object" }
  },
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "Entity" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "plural": { "type": "string" },
              "optimisticLocking": { "type": "boolean" },
              "softDelete": { "type": "boolean" },
              "tenantScoped": { "type": "boolean" },
              "scopedBy": { "type": "string", "description": "Name of a ManyToOne ref field; every read of this entity is then filtered by a per-request X-Aperture-Scope-<Field> header value (mandatory query filter, not per-user authorization)." },
              "mcp": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "Absent (or present without a value) means inherit: the entity participates in MCP. Only an explicit false excludes it. This can only subtract from the entity's REST-derived tool surface, never add to it."
                  },
                  "tools": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["list", "get", "create", "update", "delete"] },
                    "description": "Narrows the entity's effective MCP tools to this subset. The full effective set is derived(entity) ∩ Aperture ceiling ∩ this list, where derived(entity) is whatever the entity's own permissions/policies/publicOperations already permit. Listing a tool the entity's access rules don't grant, or that the Aperture ceiling excludes, is a validation error — this list can only restrict, never widen."
                  }
                }
              },
              "pagination": {
                "type": "object",
                "properties": {
                  "defaultSize": { "type": "integer" },
                  "maxSize": { "type": "integer" }
                }
              },
              "fields": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "index": { "type": "boolean" }
                  }
                }
              },
              "permissions": { 
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "policies": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "publicOperations": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hooks": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["guard", "validate", "mutate", "trigger"]
                    },
                    "on": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["create", "update", "delete"]
                      },
                      "minItems": 1,
                      "uniqueItems": true
                    },
                    "onFailure": {
                      "type": "string",
                      "enum": ["reject", "passthrough", "warn"]
                    },
                    "url": { "type": "string" },
                    "retries": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 5,
                      "default": 0,
                      "description": "Number of retry attempts on a failed hook call, opt-in (default 0 = today's behavior). This is the loosest structural ceiling across all hook types (trigger's cap); guard/validate are capped tighter (2) and mutate does not support retries at all — both enforced semantically, not by this schema, since JSON Schema cannot express a per-`type` conditional cleanly here. See docs/guide/hooks.md."
                    }
                  },
                  "required": ["type", "url"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["fields"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "OneOf" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "members": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 2,
                "uniqueItems": true
              }
            },
            "required": ["members"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "Migration" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "position": { "type": "object" },
              "rollback": { "type": "string", "minLength": 1 },
              "sql": { "type": "string" }
            },
            "required": ["sql", "rollback"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "ApertureConfig" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "defaultRoles": { "type": "array", "items": { "type": "string" } },
              "tenancyMode": {
                "type": "string",
                "enum": ["none", "pool"],
                "default": "pool"
              },
              "cli": {
                "type": "object",
                "properties": {
                  "binaryName": {
                    "type": "string",
                    "description": "Name of the generated CLI binary (e.g. 'acme'). Defaults to 'aperture'."
                  }
                }
              },
              "mcp": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "transport": { "type": "string", "enum": ["stateless"] },
                  "tools": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["list", "get", "create", "update", "delete"] },
                    "description": "A ceiling, not a default: the Aperture-wide upper bound on MCP tools any entity may expose, applied on top of what each entity's own permissions/policies/publicOperations already derive. Absent means no ceiling (all five tools remain possible, subject to each entity's own derivation and any entity-level tools narrowing)."
                  }
                }
              }
	            }
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "RoleDefinition" } } },
      "then": { "properties": { "spec": { "type": "object" } } }
    },
    {
      "if": { "properties": { "kind": { "const": "AbacPolicy" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "expression": { "type": "string" }
            },
            "required": ["expression"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "ApiVersionConfig" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "versions": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "type": "object",
                  "properties": { "status": { "type": "string" } },
                  "required": ["status"]
                }
              }
            },
            "required": ["versions"]
          }
        }
      }
    }
  ]
}
