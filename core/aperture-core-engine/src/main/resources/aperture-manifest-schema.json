{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "apiVersion": { "type": "string" },
    "kind": { 
      "type": "string",
      "enum": ["Entity", "OneOf", "Migration", "FrameworkConfig", "RoleDefinition", "AbacPolicy", "ApiVersionConfig", "PrincipalAttributeDefinition"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "spec": { "type": "object" }
  },
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "Entity" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "plural": { "type": "string" },
              "optimisticLocking": { "type": "boolean" },
              "softDelete": { "type": "boolean" },
              "tenantScoped": { "type": "boolean" },
              "scopedBy": { "type": "string", "description": "Name of a ManyToOne ref field; every read of this entity is then filtered by a per-request X-Aperture-Scope-<Field> header value (mandatory query filter, not per-user authorization)." },
              "mcp": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "tools": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["list", "get", "create", "update", "delete"] }
                  }
                }
              },
              "pagination": {
                "type": "object",
                "properties": {
                  "defaultSize": { "type": "integer" },
                  "maxSize": { "type": "integer" }
                }
              },
              "fields": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "index": { "type": "boolean" }
                  }
                }
              },
              "permissions": { 
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "policies": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "publicOperations": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hooks": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["guard", "validate", "mutate", "trigger"]
                    },
                    "on": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["create", "update", "delete"]
                      },
                      "minItems": 1,
                      "uniqueItems": true
                    },
                    "onFailure": {
                      "type": "string",
                      "enum": ["reject", "passthrough", "warn"]
                    },
                    "url": { "type": "string" }
                  },
                  "required": ["type", "url"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["fields"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "OneOf" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "members": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 2,
                "uniqueItems": true
              }
            },
            "required": ["members"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "Migration" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "position": { "type": "object" },
              "rollback": { "type": "string", "minLength": 1 },
              "sql": { "type": "string" }
            },
            "required": ["sql", "rollback"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "FrameworkConfig" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "defaultRoles": { "type": "array", "items": { "type": "string" } },
              "tenancyMode": {
                "type": "string",
                "enum": ["none", "pool"],
                "default": "pool"
              },
              "cli": {
                "type": "object",
                "properties": {
                  "binaryName": {
                    "type": "string",
                    "description": "Name of the generated CLI binary (e.g. 'acme'). Defaults to 'aperture'."
                  }
                }
              },
              "mcp": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "transport": { "type": "string", "enum": ["stateless"] },
                  "tools": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["list", "get", "create", "update", "delete"] }
                  }
                }
              }
	            }
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "RoleDefinition" } } },
      "then": { "properties": { "spec": { "type": "object" } } }
    },
    {
      "if": { "properties": { "kind": { "const": "AbacPolicy" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "expression": { "type": "string" }
            },
            "required": ["expression"]
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "ApiVersionConfig" } } },
      "then": {
        "properties": {
          "spec": {
            "type": "object",
            "properties": {
              "versions": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "type": "object",
                  "properties": { "status": { "type": "string" } },
                  "required": ["status"]
                }
              }
            },
            "required": ["versions"]
          }
        }
      }
    }
  ]
}
