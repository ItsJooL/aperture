#!/usr/bin/env bash
#MISE description="Build the aperture-audit-demo API and webhook writer module"
set -euo pipefail

TASK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEMO_DIR="$(cd "$TASK_DIR/.." && pwd)"
