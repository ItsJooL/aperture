meta {
  name: Refresh Token
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{superadminRefreshToken}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("superadminToken", res.body.accessToken);
    bru.setVar("superadminRefreshToken", res.body.refreshToken);
  }
}

assert {
  res.status: eq 200
  res.body.accessToken: isDefined
}
