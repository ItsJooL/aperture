meta {
  name: Create User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/manage/tenants/{{tenantId}}/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{superadminToken}}
}

body:json {
  {
    "username": "viewer@bruno-demo.com",
    "password": "ViewerPass123!"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("viewerUserId", res.body.id);
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}
