meta {
  name: Create User (Generated Password)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/manage/tenants/{{tenantId}}/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{superadminToken}}
}

body:json {
  {
    "username": "temp@bruno-demo.com",
    "generatePassword": true
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("tempUserId", res.body.id);
  }
}

assert {
  res.status: eq 201
  res.body.temporaryPassword: isDefined
}
