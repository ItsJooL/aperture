meta {
  name: Get Service Account Token
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/token
  body: json
  auth: none
}

body:json {
  {
    "clientId": "{{serviceAccountClientId}}",
    "clientSecret": "{{serviceAccountClientSecret}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("serviceAccountToken", res.body.accessToken);
  }
}

assert {
  res.status: eq 200
  res.body.accessToken: isDefined
}
