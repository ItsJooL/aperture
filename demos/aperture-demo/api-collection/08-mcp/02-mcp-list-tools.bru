meta {
  name: MCP List Tools
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{tenantAdminToken}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/list",
    "params": {}
  }
}

assert {
  res.status: eq 200
  res.body.result.tools: isDefined
}
