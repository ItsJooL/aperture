meta {
  name: Create Order (User)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/orders
  body: json
  auth: bearer
}

auth:bearer {
  token: {{userToken}}
}

headers {
  Content-Type: application/vnd.api+json
  Accept: application/vnd.api+json
}

body:json {
  {
    "data": {
      "type": "orders",
      "attributes": {
        "quantity": 2,
        "status": "pending"
      }
    }
  }
}

assert {
  res.status: eq 201
  res.body.data.id: isDefined
}
