meta {
  name: MCP List Tasks
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{superadminToken}}
}

headers {
  Content-Type: application/json
  Accept: application/json, text/event-stream
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "list_tasks",
      "arguments": {}
    }
  }
}

assert {
  res.status: eq 200
  res.body.result: isDefined
}
